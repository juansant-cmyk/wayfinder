# Comma-separated origins allowed to call the API (Expo web / local dev)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081,http://127.0.0.1:19006

# PostgreSQL — local Docker (default for dev + integration tests)
DATABASE_URL=postgresql+asyncpg://wayfinder:wayfinder@localhost:55432/wayfinder

# Supabase (production) — paste URI from Supabase dashboard (Direct or Session pooler)
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# JWT signing secret — change in production (Render: auto-generate or set manually)
JWT_SECRET=change-me-in-production

# Access token lifetime in hours
JWT_EXPIRE_HOURS=24

# External API providers (mock providers are used by default)
GOOGLE_MAPS_API_KEY=
HOTEL_API_KEY=
WEATHER_API_KEY=
TRAVEL_ADVISORY_API_KEY=
OPENAI_API_KEY=
LITEAPI_API_KEY=
LITEAPI_BASE_URL=https://api.liteapi.travel/v3.0
LITEAPI_GUEST_NATIONALITY=US
LITEAPI_CURRENCY=USD
# Defaults only — clients can override per request via guest_nationality & currency
# Defaults only — clients can override per request via guest_nationality & currency
# mock | liteapi — used when USE_MOCK_PROVIDERS=false
HOTEL_PROVIDER=liteapi
USE_MOCK_PROVIDERS=false
EXTERNAL_REQUEST_TIMEOUT_SECONDS=30
