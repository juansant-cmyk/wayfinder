# Copy this file to `.env` and fill in values:
#   copy .env.example .env
# Then start Postgres (database/docker compose up -d) and the API (from frontend: npm run api).

# Comma-separated origins allowed to call the API (Expo web / local dev)
CORS_ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:19006,http://127.0.0.1:8081,http://127.0.0.1:8082,http://127.0.0.1:19006

# PostgreSQL — local Docker (database/docker-compose.yml maps 55432 → 5432)
DATABASE_URL=postgresql+asyncpg://wayfinder:wayfinder@localhost:55432/wayfinder

# Supabase (production) — paste URI from Supabase dashboard
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# JWT signing secret — required. Empty / "change-me-in-production" refuse to boot.
# Generate: python scripts/generate_jwt_secret.py
JWT_SECRET=REPLACE_ME_with_output_of_generate_jwt_secret

# Access token lifetime in hours
JWT_EXPIRE_HOURS=24

# External API providers
GOOGLE_MAPS_API_KEY=
HOTEL_API_KEY=
LITEAPI_API_KEY=
LITEAPI_BASE_URL=https://api.liteapi.travel/v3.0
LITEAPI_GUEST_NATIONALITY=US
LITEAPI_CURRENCY=USD
# mock | liteapi — used when USE_MOCK_PROVIDERS=false
HOTEL_PROVIDER=mock
USE_MOCK_PROVIDERS=true
EXTERNAL_REQUEST_TIMEOUT_SECONDS=30
