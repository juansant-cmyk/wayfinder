# Comma-separated origins allowed to call the API (Expo / web dev)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081,http://127.0.0.1:19006

# PostgreSQL (async SQLAlchemy URL)
DATABASE_URL=postgresql+asyncpg://wayfinder:wayfinder@localhost:55432/wayfinder

# JWT signing secret — change in production
JWT_SECRET=change-me-in-production

# Access token lifetime in hours
JWT_EXPIRE_HOURS=24

# External API providers (mock providers are used by default)
GOOGLE_MAPS_API_KEY=
HOTEL_API_KEY=
USE_MOCK_PROVIDERS=true
EXTERNAL_REQUEST_TIMEOUT_SECONDS=10
