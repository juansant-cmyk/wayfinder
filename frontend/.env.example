# Copy this file to `.env`, fill in values, then restart Expo:
#   copy .env.example .env
#   npx expo start --clear
#
# EXPO_PUBLIC_* vars are baked in at Metro start — always --clear after edits.

# --- Pick ONE API target ---

# A) API on THIS PC + Expo web on THIS PC:
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
EXPO_PUBLIC_API_URL_WEB=http://127.0.0.1:8000

# B) API on THIS PC + Expo Go on your phone (same Wi‑Fi):
#    Run `ipconfig` → Wi‑Fi IPv4 (e.g. 192.168.1.42), then:
# EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
# EXPO_PUBLIC_API_URL_WEB=http://127.0.0.1:8000

# C) Shared Render API (no local backend needed):
# EXPO_PUBLIC_API_URL=https://wayfinder-e30f.onrender.com
# EXPO_PUBLIC_API_URL_WEB=https://wayfinder-e30f.onrender.com
